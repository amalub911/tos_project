{
  "manifest_version": 3,
  "name": "ToS Intelligence Hub",
  "version": "1.0.2",
  "description": "Sentence-level AI forensics for Terms of Service.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
